# LLM（OpenAI-compatible，預設 Ollama）
LLM_BASE_URL=http://your-ollama-host:11434/v1
LLM_MODEL=your-model-name
LLM_API_KEY=ollama

# TDX 運輸資料流通服務（https://tdx.transportdata.tw/）
TDX_CLIENT_ID=your-client-id
TDX_CLIENT_SECRET=your-client-secret

# Kiosk 設定：這台機器部署在哪個站牌
KIOSK_STOP=雲林科技大學

# Kiosk 方向（選填）
# 去程跟回程有各自實體站牌時，設定這台機器對應哪個方向
# 填「去程」或「回程」（跟路線無關，系統會自動對應各路線的終點站顯示「往 X」）
# 不填 = 顯示兩個方向（適合去回程共用同一站牌）
# KIOSK_DIRECTION=回程
