# 最小可跑設定（CLI / chat API 必填）
# LLM（OpenAI-compatible，預設 Ollama）
LLM_BASE_URL=http://your-ollama-host:11434/v1
LLM_MODEL=your-model-name
LLM_API_KEY=ollama

# Kiosk 設定：這台機器部署在哪個站牌
KIOSK_STOP=雲林科技大學

# Kiosk 精確座標（選填，強烈建議設定）
# 設定後 route planning 直接用此座標為出發點，避免同名站牌平均座標偏移問題。
# 用 Google Maps 右鍵點站牌位置 → 複製座標即可。
# KIOSK_LAT=23.6969
# KIOSK_LON=120.5385

# 下面設定依功能選填；沒開對應功能時可先保持註解。

# Kiosk 方向（選填）
# 去程跟回程有各自實體站牌時，設定這台機器對應哪個方向
# 填「去程」或「回程」（跟路線無關，系統會自動對應各路線的終點站顯示「往 X」）
# 不填 = 顯示兩個方向（適合去回程共用同一站牌）
# KIOSK_DIRECTION=回程

# 可觀測性（選填）：OpenTelemetry OTLP/HTTP endpoint
# 目前預設觀測後端選 SigNoz；self-host 在本機時 OTLP/HTTP 預設可用 4318
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=taigi-bus-agent

# 路線規劃 / MOOVO（選填）
# TDX credentials 只在更新 GTFS 或查 MOOVO 站點 API 時需要。
# TDX_CLIENT_ID=
# TDX_CLIENT_SECRET=

# MOOVO 站點/即時可借資料快取秒數（選填，預設 60）
# MOOVO_CACHE_TTL_SECONDS=60

# OTP route planning provider（選填，預設本機 Docker service）
# OTP_BASE_URL=http://localhost:8081
# YUNLIN_STOP_INDEX_PATH=otp/data/yunlin-stop-index.json

# 語音功能（選填）
# ASR（Qwen3-ASR 微調，OpenAI /v1/audio/transcriptions 格式）
# ASR_BASE_URL=http://xxx.xxx.xxx.xxx:8000
# ASR_MODEL=qwen3-asr
# ASR_API_KEY=

# TTS（OpenAI /v1/audio/speech 格式，漢羅 → Taibun → Piper TTS）
# TTS_BASE_URL=https://your-tts-host.trycloudflare.com
# TTS_MODEL=tts-1
# TTS_VOICE=taigi
# TTS_API_KEY=

# Route planning API 若要讓另一個 frontend dev server 跨來源呼叫再設定
# API_CORS_ORIGINS=http://127.0.0.1:5173
